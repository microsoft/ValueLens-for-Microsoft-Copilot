{
  "$comment": "Power Automate / Logic Apps flow definition. Lands the Microsoft 365 Admin Center > Copilot > Cost management > Consumption per-user CSV export (columns: User Principal Name, Cowork Credits, WorkIQ Credits, Other Credits, Last Activity Date) from inbound email straight into the Fabric Lakehouse Files/cost_consumption folder via the OneLake DFS (ADLS Gen2) API. This is the Cowork/WorkIQ/Other credit surface split that the Power Platform MCSMessages exports do NOT contain. Import via Power Automate > My flows > Import, then fix up the Office 365 Outlook connection + the parameter values. See COST-CONSUMPTION.md.",
  "definition": {
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "$connections": { "defaultValue": {}, "type": "Object" },
      "OneLakeWorkspace": {
        "defaultValue": "<your-workspace>",
        "type": "String",
        "metadata": { "description": "Fabric workspace name (or GUID) that holds the lakehouse." }
      },
      "OneLakeLakehouse": {
        "defaultValue": "<your-lakehouse>",
        "type": "String",
        "metadata": { "description": "Lakehouse name WITHOUT the .Lakehouse suffix." }
      },
      "TargetFolder": {
        "defaultValue": "Files/cost_consumption",
        "type": "String",
        "metadata": { "description": "Destination folder inside the lakehouse. Matches SOURCE_DIR in Copilot_Cost_Consumption_Ingester.ipynb." }
      },
      "SubjectFilter": {
        "defaultValue": "Copilot Cost Management",
        "type": "String",
        "metadata": { "description": "Only emails whose subject contains this string are processed." }
      },
      "FileNamePrefix": {
        "defaultValue": "",
        "type": "String",
        "metadata": { "description": "Optional case-insensitive filename guard. The MAC Cost management export filename is not fixed, so this defaults to empty (accept any .csv attachment on a subject-matched mail). Set it once you know the real export prefix to be stricter." }
      },
      "TenantId":     { "defaultValue": "<tenant-guid>", "type": "String" },
      "ClientId":     { "defaultValue": "<app-reg-client-id>", "type": "String" },
      "ClientSecret": { "defaultValue": "<keyvault-reference>", "type": "SecureString" }
    },
    "triggers": {
      "When_a_new_email_arrives_V3": {
        "type": "OpenApiConnectionNotification",
        "inputs": {
          "host": {
            "connectionName": "shared_office365",
            "operationId": "OnNewEmailV3",
            "apiId": "/providers/Microsoft.PowerApps/apis/shared_office365"
          },
          "parameters": {
            "subjectFilter": "@parameters('SubjectFilter')",
            "hasAttachments": "Yes",
            "includeAttachments": true,
            "importance": "Any"
          }
        },
        "splitOn": "@triggerOutputs()?['body/value']"
      }
    },
    "actions": {
      "For_each_attachment": {
        "type": "Foreach",
        "foreach": "@triggerOutputs()?['body/attachments']",
        "actions": {
          "Only_cost_CSVs": {
            "type": "If",
            "expression": {
              "and": [
                { "endsWith": [ "@toLower(items('For_each_attachment')?['name'])", ".csv" ] },
                {
                  "or": [
                    { "equals": [ "@parameters('FileNamePrefix')", "" ] },
                    { "startsWith": [ "@toLower(items('For_each_attachment')?['name'])", "@toLower(parameters('FileNamePrefix'))" ] }
                  ]
                }
              ]
            },
            "actions": {
              "Create_file_PUT": {
                "type": "Http",
                "inputs": {
                  "method": "PUT",
                  "uri": "https://onelake.dfs.fabric.microsoft.com/@{encodeURIComponent(parameters('OneLakeWorkspace'))}/@{encodeURIComponent(concat(parameters('OneLakeLakehouse'), '.Lakehouse'))}/@{parameters('TargetFolder')}/@{items('For_each_attachment')?['name']}?resource=file",
                  "authentication": {
                    "type": "ActiveDirectoryOAuth",
                    "authority": "https://login.microsoftonline.com",
                    "tenant": "@parameters('TenantId')",
                    "audience": "https://storage.azure.com/",
                    "clientId": "@parameters('ClientId')",
                    "secret": "@parameters('ClientSecret')"
                  }
                }
              },
              "Append_content_PATCH": {
                "type": "Http",
                "runAfter": { "Create_file_PUT": [ "Succeeded" ] },
                "inputs": {
                  "method": "PATCH",
                  "uri": "https://onelake.dfs.fabric.microsoft.com/@{encodeURIComponent(parameters('OneLakeWorkspace'))}/@{encodeURIComponent(concat(parameters('OneLakeLakehouse'), '.Lakehouse'))}/@{parameters('TargetFolder')}/@{items('For_each_attachment')?['name']}?action=append&position=0",
                  "headers": { "Content-Type": "application/octet-stream" },
                  "body": "@items('For_each_attachment')?['contentBytes']",
                  "authentication": {
                    "type": "ActiveDirectoryOAuth",
                    "authority": "https://login.microsoftonline.com",
                    "tenant": "@parameters('TenantId')",
                    "audience": "https://storage.azure.com/",
                    "clientId": "@parameters('ClientId')",
                    "secret": "@parameters('ClientSecret')"
                  }
                }
              },
              "Flush_content_PATCH": {
                "type": "Http",
                "runAfter": { "Append_content_PATCH": [ "Succeeded" ] },
                "inputs": {
                  "method": "PATCH",
                  "uri": "https://onelake.dfs.fabric.microsoft.com/@{encodeURIComponent(parameters('OneLakeWorkspace'))}/@{encodeURIComponent(concat(parameters('OneLakeLakehouse'), '.Lakehouse'))}/@{parameters('TargetFolder')}/@{items('For_each_attachment')?['name']}?action=flush&position=@{length(items('For_each_attachment')?['contentBytes'])}",
                  "authentication": {
                    "type": "ActiveDirectoryOAuth",
                    "authority": "https://login.microsoftonline.com",
                    "tenant": "@parameters('TenantId')",
                    "audience": "https://storage.azure.com/",
                    "clientId": "@parameters('ClientId')",
                    "secret": "@parameters('ClientSecret')"
                  }
                }
              }
            },
            "else": { "actions": {} }
          }
        }
      }
    }
  }
}
